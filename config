set $mod Mod4

include /etc/sway/config.d/*

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango: JetBrainsMono Nerd Font Mono 10

input type:keyboard {
	xkb_layout fr
	xkb_numlock enabled
}

input type:pointer {
	accel_profile "flat"
}
# theming

gaps inner 0
default_border pixel 4
default_floating_border pixel 4

#client.focused #FF4949 #FF4949 #FFFFFF #9C9EFE #FF4949

seat * xcursor_theme McMojave-cursors 28
# screen settings
output DP-1 {
	pos 0 0 mode 2560x1440@280Hz
	adaptive_sync off
	render_bit_depth 10
	allow_tearing yes
	scale 1
	max_render_time off
	hdr off
	bg #000000 solid_color
}

output DP-2 {
	pos 2560 0 mode 2560x1440@200Hz
	adaptive_sync off
	render_bit_depth 10
	allow_tearing no
	#max_render_time off
	hdr off
	bg ~/wallpaper.jpg fill
}
# Reload the configuration file
bindsym $mod+Shift+c reload

# smart borders (disable borders when there's only one window in the focused workspace)
smart_borders off

# toggle gaps
bindsym $mod+g exec swaymsg gaps inner current toggle 15

# idle management
exec ~/.config/sway/binaries/gamepad_event_watcher
exec ~/.config/sway/scripts/swayidle_wrapper.sh
# rofi
bindsym $mod+Tab exec ~/.config/sway/scripts/rofi.sh

#bar {
#	swaybar_command eww --force-wayland open myenvbar
#	mode dock
#	position top
#}
# toggle bar visibility
bindsym $mod+Shift+dead_circumflex exec python ~/.config/deskenv/bar.py -t
#bindsym --whole-window $mod+BTN_FORWARD exec killall -SIGUSR1 waybar

# kill focused window
bindsym $mod+Shift+q kill
# BTN_FORWARD is the left lateral button on the mouse (the "sniper" one).
bindsym --whole-window $mod+Shift+BTN_MIDDLE kill

# default workspace for apps
#assign [class="com.github.th_ch.youtube_music"] workspace 3
#assign [class="ZapZap"] workspace 4

# make certain windows floating by default
for_window [title="File Operation Progress" app_id="thunar"] floating enable
for_window [title="Rename .*" app_id="thunar"] floating enable
for_window [title="Confirm to replace files" app_id="thunar"] floating enable
for_window [title="galculator" app_id="galculator"] floating enable
for_window [title="proton_msg_box"] floating enable

# wallpaper
#exec --no-startup-id ~/.config/sway/scripts/wallpaper.sh

# apps to start on sway startup
#exec ~/.config/sway/scripts/eww_wrapper &> ~/eww_wrapper.log

# run eww daemon
exec --no-startup-id bash -c "[[ -z \"$(ss -lx | grep eww-server | grep -v grep)\" ]] && eww daemon"
# run my custom daemon
exec python ~/.config/deskenv/daemon.py &> ~/.var/log/deskenv/daemon.log
# run my custom daemon for eww
#exec ~/.config/eww/scripts/daemon.sh

bindsym XF86MonBrightnessUp exec --no-startup-id python ~/.config/deskenv/brightness.py -i 5
bindsym XF86MonBrightnessDown exec --no-startup-id python ~/.config/deskenv/brightness.py -d 5

# audio controls
bindsym XF86AudioRaiseVolume exec --no-startup-id python ~/.config/deskenv/volume.py -i 2
bindsym XF86AudioLowerVolume exec --no-startup-id python ~/.config/deskenv/volume.py -d 2

bindsym XF86AudioMute exec --no-startup-id python ~/.config/deskenv/volume.py -t

# media controls (MPRIS)
bindsym XF86AudioPlay exec --no-startup-id ~/.config/deskenv/bash/playback.sh --play-pause
bindsym XF86AudioNext exec --no-startup-id ~/.config/deskenv/bash/playback.sh --next
bindsym XF86AudioPrev exec --no-startup-id ~/.config/deskenv/bash/playback.sh --previous

# screenshot
bindsym Print exec --no-startup-id bash -c "env GRIM_DEFAULT_DIR=~/pictures/screenshots/ grim"

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
tiling_drag enable

# start a terminal
bindsym $mod+Return exec i3-sensible-terminal

# There also is i3-dmenu-desktop which only displays applications shipping a
# .desktop file. It is a wrapper around dmenu, so you need that installed.
# bindcode $mod+40 exec --no-startup-id i3-dmenu-desktop

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# split in horizontal orientation
bindsym $mod+o split h

# split in vertical orientation
bindsym $mod+z split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
bindsym $mod+d focus child

# Define names for default workspace for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $output1_ws1 "1-1"
set $output1_ws2 "1-2"
set $output1_ws3 "1-3"
set $output1_ws4 "1-4"
set $output1_ws5 "1-5"
set $output1_ws6 "1-6"
set $output1_ws7 "1-7"
set $output1_ws8 "1-8"

set $output2_ws1 "2-1"
set $output2_ws2 "2-2"
set $output2_ws3 "2-3"
set $output2_ws4 "2-4"
set $output2_ws5 "2-5"
set $output2_ws6 "2-6"
set $output2_ws7 "2-7"
set $output2_ws8 "2-8"

# assign workspaces to outputs (monitors)

workspace $output1_ws1 output DP-1
workspace $output1_ws2 output DP-1
workspace $output1_ws3 output DP-1
workspace $output1_ws4 output DP-1
workspace $output1_ws5 output DP-1
workspace $output1_ws6 output DP-1
workspace $output1_ws7 output DP-1
workspace $output1_ws8 output DP-1

workspace $output2_ws1 output DP-2
workspace $output2_ws2 output DP-2
workspace $output2_ws3 output DP-2
workspace $output2_ws4 output DP-2
workspace $output2_ws5 output DP-2
workspace $output2_ws6 output DP-2
workspace $output2_ws7 output DP-2
workspace $output2_ws8 output DP-2

# switch to workspace
bindsym $mod+ampersand exec python ~/.config/deskenv/workspace.py --switch 1
bindsym $mod+eacute exec python ~/.config/deskenv/workspace.py --switch 2
bindsym $mod+quotedbl exec python ~/.config/deskenv/workspace.py --switch 3
bindsym $mod+apostrophe exec python ~/.config/deskenv/workspace.py --switch 4
bindsym $mod+parenleft exec python ~/.config/deskenv/workspace.py --switch 5
bindsym $mod+minus exec python ~/.config/deskenv/workspace.py --switch 6
bindsym $mod+egrave exec python ~/.config/deskenv/workspace.py --switch 7
bindsym $mod+underscore exec python ~/.config/deskenv/workspace.py --switch 8
bindsym $mod+ccedilla exec python ~/.config/deskenv/workspace.py --switch 9
bindsym $mod+agrave exec python ~/.config/deskenv/workspace.py --switch 10

# move focused container to workspace
bindsym $mod+Shift+ampersand exec python ~/.config/deskenv/workspace.py --move 1
bindsym $mod+Shift+eacute exec python ~/.config/deskenv/workspace.py --move 2
bindsym $mod+Shift+quotedbl exec python ~/.config/deskenv/workspace.py --move 3
bindsym $mod+Shift+apostrophe exec python ~/.config/deskenv/workspace.py --move 4
bindsym $mod+Shift+parenleft exec python ~/.config/deskenv/workspace.py --move 5
bindsym $mod+Shift+minus exec python ~/.config/deskenv/workspace.py --move 6
bindsym $mod+Shift+egrave exec python ~/.config/deskenv/workspace.py --move 7
bindsym $mod+Shift+underscore exec python ~/.config/deskenv/workspace.py --move 8
bindsym $mod+Shift+ccedilla exec python ~/.config/deskenv/workspace.py --move 9
bindsym $mod+Shift+agrave exec python ~/.config/deskenv/workspace.py --move 10


# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart

# exit sway
bindsym $mod+Shift+e exit

# resize window (you can also use the mouse for that)
mode "resize" {
        # These bindings trigger as soon as you enter the resize mode

        # Pressing left will shrink the window’s width.
        # Pressing right will grow the window’s width.
        # Pressing up will shrink the window’s height.
        # Pressing down will grow the window’s height.
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym j resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt

        # same bindings, but for the arrow keys
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"
